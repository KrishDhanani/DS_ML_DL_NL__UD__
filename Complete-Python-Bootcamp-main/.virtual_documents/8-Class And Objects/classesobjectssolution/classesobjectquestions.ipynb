# Assignment 7:

class Address:

    def __init__(self, street, city, zipcode):
        self.street = street
        self.city = city
        self.zipcode = zipcode

class Person(Address):
    
    def __init__(self, street, city, zipcode):
        super().__init__(street, city, zipcode)

    def __str__(self):
        return f"The Person address is on street:{self.street} city:{self.city} zipcode:{self.zipcode}"
person = Person("LM road", "stutgaurd", 7999)
print(person)
    



